      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $('Generate Ticket ID & Metadata').item.json;\nlet routeKey;\nif (item.confidence < 80) {\n  routeKey = 'ManualReview';\n} else {\n  const cat = (item.category || '').toLowerCase();\n  if (cat === 'billing') routeKey = 'Billing';\n  else if (cat === 'technical support' || cat === 'bug report') routeKey = 'Technical';\n  else if (cat === 'sales') routeKey = 'Sales';\n  else if (cat === 'refund') routeKey = 'Refund';\n  else routeKey = 'General';\n}\nreturn { json: { ...item, routeKey } };"
      },
