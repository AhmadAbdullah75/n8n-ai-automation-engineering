    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item.json;\nconst errors = [];\nconst fullName = (item['Full Name'] || '').toString().trim();\nconst email = (item['Email Address'] || '').toString().trim();\nconst company = (item['Company Name'] || '').toString().trim();\nconst subject = (item['Subject'] || '').toString().trim();\nconst description = (item['Description of the Issue'] || '').toString().trim();\n\nif (!fullName) errors.push('Full Name is required');\nif (!email) errors.push('Email Address is required');\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nif (email && !emailRegex.test(email)) errors.push('Email Address format is invalid');\nif (!subject) errors.push('Subject is required');\nif (!description) errors.push('Description of the Issue is required');\n\nreturn {\n  json: {\n    fullName,\n    email,\n    company,\n    subject,\n    description,\n    isValid: errors.length === 0,\n    validationErrors: errors\n  }\n};"
      },
